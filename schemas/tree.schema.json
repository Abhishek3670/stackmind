{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "stackmind TREE.yaml",
  "type": "object",
  "required": [
    "schema_version",
    "tree_version",
    "agents"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "tree_version": {
      "type": "integer",
      "minimum": 1
    },
    "graph_version": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "string",
          "pattern": "^[A-Fa-f0-9]{64}$"
        }
      ]
    },
    "last_updated": {
      "oneOf": [
        {
          "type": "string",
          "pattern": "^\\{\\{[A-Z0-9_]+\\}\\}$"
        },
        {
          "type": "string"
        }
      ]
    },
    "current_phase": {
      "type": "string"
    },
    "phase_status": {
      "type": "string",
      "enum": [
        "INIT",
        "PLANNING",
        "ACTIVE",
        "COMPLETE",
        "BLOCKED"
      ]
    },
    "release": {
      "type": "string"
    },
    "work_orders": {
      "type": "object",
      "properties": {
        "total_active": {
          "type": "integer",
          "minimum": 0
        },
        "total_blocked": {
          "type": "integer",
          "minimum": 0
        },
        "total_completed": {
          "type": "integer",
          "minimum": 0
        },
        "index_file": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "agents": {
      "type": "object",
      "patternProperties": {
        "^[a-z-]+$": {
          "type": "object",
          "required": [
            "status",
            "session_count"
          ],
          "properties": {
            "status": {
              "type": "string",
              "enum": [
                "active",
                "assigned",
                "idle",
                "blocked",
                "non_compliant"
              ]
            },
            "session_count": {
              "type": "integer",
              "minimum": 0
            },
            "last_task": {
              "type": "string"
            },
            "next_task": {
              "type": "string"
            },
            "blockers": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "boot_version": {
              "type": "string"
            },
            "assigned_work_orders": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": false
    },
    "inbox_unread": {
      "type": "object",
      "patternProperties": {
        "^[a-z-]+$": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    "latest_decision": {
      "type": [
        "string",
        "null"
      ]
    },
    "latest_decision_title": {
      "type": [
        "string",
        "null"
      ]
    },
    "decisions_pending": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "active_dependencies": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "quality": {
      "type": "object",
      "additionalProperties": true
    },
    "compliance": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    }
  },
  "additionalProperties": true
}
