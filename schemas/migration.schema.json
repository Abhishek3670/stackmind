{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "stackmind Migration Manifest",
  "type": "object",
  "required": [
    "from_version",
    "to_version",
    "description",
    "up",
    "down"
  ],
  "properties": {
    "from_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "to_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "description": {
      "type": "string"
    },
    "up": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/action"
      }
    },
    "down": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/action"
      }
    }
  },
  "additionalProperties": false,
  "definitions": {
    "action": {
      "type": "object",
      "required": [
        "action"
      ],
      "properties": {
        "action": {
          "type": "string",
          "enum": [
            "add_field",
            "remove_field",
            "add_dir",
            "remove_dir",
            "rename",
            "set_value"
          ]
        },
        "file": {
          "type": "string"
        },
        "path": {
          "type": "string"
        },
        "field": {
          "type": "string"
        },
        "value": {},
        "from": {
          "type": "string"
        },
        "to": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  }
}
